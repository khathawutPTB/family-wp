# PostgreSQL connection string (e.g. from Neon, Railway, or local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Secret used to sign JWT access tokens (use a long random string in production)
JWT_SECRET="change-this-to-a-long-random-secret"

# JWT token lifetime
JWT_EXPIRES_IN="7d"

# Port the API server listens on
PORT=4000

# Comma-separated list of allowed CORS origins
CORS_ORIGIN="http://localhost:5173"

# Web Push (browser notifications) — generate with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY="change-this"
VAPID_PRIVATE_KEY="change-this"
VAPID_SUBJECT="mailto:you@example.com"

# Shared secret the daily notification cron trigger must send — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="change-this-to-a-long-random-secret"
