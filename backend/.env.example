# Local dev default: SQLite, zero setup, no password needed.
DATABASE_URL="file:./dev.db"

# To use PostgreSQL instead (recommended for production), change
# datasource.provider to "postgresql" in prisma/schema.prisma, remove
# any leftover dev.db file, then set:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Secret used to sign JWT access tokens (use a long random string in production)
JWT_SECRET="change-this-to-a-long-random-secret"

# JWT token lifetime
JWT_EXPIRES_IN="7d"

# Port the API server listens on
PORT=4000

# Comma-separated list of allowed CORS origins
CORS_ORIGIN="http://localhost:5173"
